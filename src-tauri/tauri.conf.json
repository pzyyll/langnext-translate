{
	"productName": "LangNext",
	"version": "0.1.0",
	"identifier": "com.de.agoto.langnext.app",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:1234",
		"beforeDevCommand": "bun run dev",
		"beforeBuildCommand": "bun run generate"
	},
	"app": {
		"withGlobalTauri": true,
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"shortDescription": "LangNext translation app.",
		"longDescription": "LangNext is a app for LangNext.",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/black-bg/icon.ico"
		],
		"resources": ["resources/languages.json"]
	},
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json"
}
